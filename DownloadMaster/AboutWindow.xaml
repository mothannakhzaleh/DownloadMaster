<Window x:Class="DownloadMaster.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Icon="Assets/app.ico"
        Height="540" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="/Assets/app-icon.png" Width="56" Height="56" Margin="0,0,16,0" RenderOptions.BitmapScalingMode="HighQuality" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="DownloadMaster" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock x:Name="VersionText" Text="Version 1.0.0" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" FontSize="14" LineHeight="22"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                <TextBlock x:Name="FeaturesText" TextWrapping="Wrap" FontSize="13" LineHeight="20"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,14" />
                <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10">
                    <Run x:Name="AuthorPrefixRun" Text="Copyright © 2026 " />
                    <Hyperlink NavigateUri="https://github.com/mothannakhzaleh/DownloadMaster" RequestNavigate="Link_RequestNavigate">mothannakh</Hyperlink>
                </TextBlock>
                <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6">
                    <Hyperlink NavigateUri="https://github.com/mothannakhzaleh/DownloadMaster" RequestNavigate="Link_RequestNavigate">GitHub: mothannakhzaleh/DownloadMaster</Hyperlink>
                </TextBlock>
                <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}">
                    <Hyperlink NavigateUri="https://satisfy.live/" RequestNavigate="Link_RequestNavigate">https://satisfy.live/</Hyperlink>
                </TextBlock>
                <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,14">
                    <Hyperlink NavigateUri="https://www.youtube.com/@ToPSourceDevelopment" RequestNavigate="Link_RequestNavigate">YouTube: @ToPSourceDevelopment</Hyperlink>
                </TextBlock>
                <TextBlock x:Name="LicenseText" TextWrapping="Wrap" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" x:Name="CloseButton" Content="Close" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right" Margin="0,16,0,0" Padding="20,10" Click="CloseButton_Click" />
    </Grid>
</Window>
