<UserControl x:Class="DownloadMaster.Views.ImageConvertorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             DragOver="Image_DragOver"
             Drop="Image_Drop"
             DragLeave="Image_DragLeave">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MaxHeight="520" />
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="240" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="240" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="14" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="ImageSourceTitle" Text="Image source" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                        <TextBlock x:Name="ImageModeLabel" Text="Conversion mode" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton x:Name="ImageSingleFileRadio" Content="Single image" GroupName="ImageMode" IsChecked="True" />
                            <RadioButton x:Name="ImageFolderRadio" Content="Folder" GroupName="ImageMode" Margin="16,0,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="ImageInputLabel" Text="Image file" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ImageInputPathBox" IsReadOnly="True" TextChanged="ImageInputPathBox_TextChanged" />
                            <Button x:Name="ImageBrowseInputButton" Grid.Column="1" Content="Browse"
                                    Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                    Click="BrowseImageInput_Click" />
                        </Grid>
                        <CheckBox x:Name="ImageIncludeSubfoldersCheck" Content="Include subfolders"
                                  Visibility="Collapsed" Margin="0,0,0,12" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="14" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="ImageOutputTitle" Text="Output &amp; optimization" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                        <TextBlock x:Name="ImageFormatLabel" Text="Target format" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <ComboBox x:Name="ImageFormatCombo" Margin="0,0,0,12" SelectedIndex="0">
                            <ComboBoxItem Content="PNG" Tag="Png" />
                            <ComboBoxItem Content="JPEG" Tag="Jpeg" />
                            <ComboBoxItem Content="WebP" Tag="WebP" />
                            <ComboBoxItem Content="BMP" Tag="Bmp" />
                            <ComboBoxItem Content="TIFF" Tag="Tiff" />
                            <ComboBoxItem Content="GIF" Tag="Gif" />
                            <ComboBoxItem Content="TGA" Tag="Tga" />
                            <ComboBoxItem Content="DDS" Tag="Dds" />
                        </ComboBox>
                        <TextBlock x:Name="ImageSaveToLabel" Text="Save to" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <StackPanel Margin="0,0,0,12">
                            <RadioButton x:Name="ImageSameFolderRadio" Content="Same folder (optimize in place or replace extension)"
                                         GroupName="ImageOutput" IsChecked="True" />
                            <RadioButton x:Name="ImageCustomFolderRadio" Content="Custom output folder" GroupName="ImageOutput" />
                        </StackPanel>
                        <Grid x:Name="ImageOutputFolderPanel" Margin="0,0,0,12" IsEnabled="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ImageOutputFolderBox" IsReadOnly="True" />
                            <Button x:Name="ImageBrowseOutputButton" Grid.Column="1" Content="Browse"
                                    Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                    Click="BrowseImageOutput_Click" />
                        </Grid>
                        <TextBlock x:Name="ImageResolutionLabel" Text="Resolution" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <ComboBox x:Name="ImageResolutionCombo" Margin="0,0,0,12" DisplayMemberPath="Label" />
                        <CheckBox x:Name="ImageOptimizeCheck" Content="Optimize file size" IsChecked="True" Margin="0,0,0,8" />
                        <StackPanel x:Name="ImageOptimizePanel" Margin="8,0,0,0">
                            <TextBlock x:Name="ImageOptimizeHint" Text="PNG: palette optimization — reduces colors, keeps transparency."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10" />
                            <TextBlock x:Name="ImagePngColorsLabel" Text="PNG colors (16–256)" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <Grid x:Name="ImagePngColorsPanel" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="ImagePngColorsSlider" Minimum="16" Maximum="256" Value="256"
                                        TickFrequency="16" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Width="32" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="{Binding ElementName=ImagePngColorsSlider, Path=Value, StringFormat={}{0:0}}" />
                            </Grid>
                            <CheckBox x:Name="ImagePngDitherCheck" Content="Dither smooth gradients (Floyd–Steinberg)"
                                      Margin="0,0,0,10" />
                            <TextBlock x:Name="ImageQualityLabel" Text="JPEG / WebP quality (%)" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" Visibility="Collapsed" />
                            <Grid x:Name="ImageQualityPanel" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="ImageQualitySlider" Minimum="50" Maximum="100" Value="85"
                                        TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Width="36" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="{Binding ElementName=ImageQualitySlider, Path=Value, StringFormat={}{0:0}}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="ImagePreviewDropZone" Grid.Column="4" Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14"
                    AllowDrop="True" DragOver="Image_DragOver" Drop="Image_Drop" DragLeave="Image_DragLeave">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="80" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ImagePreviewTitle" Text="Preview &amp; queue" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />
                    <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Height="120" Margin="0,0,0,10" ClipToBounds="True">
                        <Grid>
                            <Image x:Name="ImagePreviewImage" Stretch="Uniform" Margin="8" />
                            <StackPanel x:Name="ImagePreviewPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12">
                                <TextBlock x:Name="ImagePreviewTitleText" Text="Drop an image or folder"
                                           FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" TextAlignment="Center" />
                                <TextBlock x:Name="ImagePreviewDetails" Text="Preview updates when you select a source."
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                           TextAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ListView x:Name="ImageIncludedFilesList" Grid.Row="2" BorderThickness="0" Background="Transparent"
                              SelectionChanged="ImageIncludedFilesList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2,0,2">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Details}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,12,0,12">
            <Grid MinHeight="100">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="60" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ImageResultsTitle" Text="Image result" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="ImageResultsSummaryText" Grid.Column="1" VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Text="No conversion yet" />
                </Grid>
                <ProgressBar x:Name="ImageResultsProgressBar" Grid.Row="1" Margin="0,10,0,10" Minimum="0" Maximum="100"
                             Value="0" Visibility="Collapsed" Height="6" />
                <ListView x:Name="ImageResultsList" Grid.Row="2" MinHeight="60" BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding Status}" />
                            <GridViewColumn Header="File" Width="180" DisplayMemberBinding="{Binding FileName}" />
                            <GridViewColumn Header="Size change" Width="200" DisplayMemberBinding="{Binding SizeChange}" />
                            <GridViewColumn Header="Details" Width="360" DisplayMemberBinding="{Binding Detail}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="ImageStatusText" Text="Ready" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
                <ProgressBar x:Name="ImageProgressBar" Margin="0,8,16,0" Minimum="0" Maximum="100" Value="0"
                             Visibility="Collapsed" Height="6" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="ImageClearResultsButton" Content="Clear result" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0" Click="ClearImageResults_Click" />
                <Button x:Name="ImageConvertButton" Content="Convert images" Style="{StaticResource PrimaryButton}"
                        MinWidth="140" Click="ConvertImages_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
