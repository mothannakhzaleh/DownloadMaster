<UserControl x:Class="DownloadMaster.Views.AudioConvertorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             DragOver="Audio_DragOver"
             Drop="Audio_Drop"
             DragLeave="Audio_DragLeave">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MaxHeight="520" />
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="240" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="240" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="14" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="AudioSourceTitle" Text="Audio source" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                        <TextBlock x:Name="AudioSourceHint" Text="Single audio or video file"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12" />
                        <TextBlock x:Name="AudioFileLabel" Text="Input file" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AudioInputPathBox" IsReadOnly="True" />
                            <Button x:Name="AudioBrowseInputButton" Grid.Column="1" Content="Browse"
                                    Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                    Click="BrowseAudioInput_Click" />
                        </Grid>
                        <TextBlock x:Name="AudioOperationLabel" Text="Operation" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <StackPanel Margin="0,0,0,12">
                            <RadioButton x:Name="AudioConvertRadio" Content="Convert — change to another format"
                                         GroupName="AudioOperation" IsChecked="True" />
                            <RadioButton x:Name="AudioOptimizeRadio" Content="Optimize — re-encode same format"
                                         GroupName="AudioOperation" />
                        </StackPanel>
                        <StackPanel x:Name="AudioFormatPanel">
                            <TextBlock x:Name="AudioFormatLabel" Text="Target format" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <ComboBox x:Name="AudioFormatCombo" DisplayMemberPath="DisplayName" SelectedValuePath="Format" />
                        </StackPanel>
                        <TextBlock x:Name="AudioOperationHint"
                                   Text="Convert extracts audio and re-encodes into the selected format."
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="14" VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock x:Name="AudioOutputTitle" Text="Output" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                    <TextBlock x:Name="AudioQualityLabel" Text="Quality" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="AudioQualityCombo" Margin="0,0,0,12" SelectedValuePath="Label">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" />
                                    <TextBlock Grid.Column="1" Text="{Binding BitrateText}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="16,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock x:Name="AudioSaveToLabel" Text="Save to" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <StackPanel Margin="0,0,0,12">
                        <RadioButton x:Name="AudioSameFolderRadio" Content="Same folder (optimize in place or replace extension)"
                                     GroupName="AudioOutput" IsChecked="True" />
                        <RadioButton x:Name="AudioCustomFolderRadio" Content="Custom output folder" GroupName="AudioOutput" />
                    </StackPanel>
                    <Grid x:Name="AudioOutputFolderPanel" Margin="0,0,0,12" IsEnabled="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AudioOutputFolderBox" IsReadOnly="True" />
                        <Button x:Name="AudioBrowseOutputButton" Grid.Column="1" Content="Browse"
                                Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                Click="BrowseAudioOutput_Click" />
                    </Grid>
                    <TextBlock x:Name="AudioQualityHint"
                               Text="Quality applies to MP3, M4A, OGG, MP2, AMR, and iPhone ringtone."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border x:Name="AudioInfoDropZone" Grid.Column="4" Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14"
                    AllowDrop="True" DragOver="Audio_DragOver" Drop="Audio_Drop" DragLeave="Audio_DragLeave">
                <StackPanel>
                    <TextBlock x:Name="AudioInfoTitle" Text="Audio info" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" MinHeight="120" Padding="12" Margin="0,0,0,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="AudioInfoTitleText" Text="Drop an audio or video file" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="AudioInfoDetails" Text="Codec, channels, duration, and size appear here."
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <TextBlock x:Name="AudioFfmpegStatus" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="AudioSupportedLabel" Text="Supported inputs" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBlock x:Name="AudioSupportedText"
                               Text="MP3, WAV, M4A, FLAC, OGG, AAC, WMA, AMR, and video files (audio track extracted)."
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,12,0,12">
            <Grid MinHeight="100">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="60" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="AudioResultsTitle" Text="Audio result" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="AudioResultsSummaryText" Grid.Column="1" VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Text="No conversion yet" />
                </Grid>
                <ProgressBar x:Name="AudioResultsProgressBar" Grid.Row="1" Margin="0,10,0,10" Minimum="0" Maximum="100"
                             Value="0" Visibility="Collapsed" Height="6" />
                <ListView x:Name="AudioResultsList" Grid.Row="2" MinHeight="60" BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn x:Name="AudioResultStatusCol" Header="Status" Width="80" DisplayMemberBinding="{Binding Status}" />
                            <GridViewColumn x:Name="AudioResultFileCol" Header="File" Width="180" DisplayMemberBinding="{Binding FileName}" />
                            <GridViewColumn x:Name="AudioResultSizeCol" Header="Size change" Width="200" DisplayMemberBinding="{Binding SizeChange}" />
                            <GridViewColumn x:Name="AudioResultDetailsCol" Header="Details" Width="360" DisplayMemberBinding="{Binding Detail}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="AudioStatusText" Text="Ready" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
                <ProgressBar x:Name="AudioProgressBar" Margin="0,8,16,0" Minimum="0" Maximum="100" Value="0"
                             Visibility="Collapsed" Height="6" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="AudioClearResultsButton" Content="Clear result" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0" Click="ClearAudioResults_Click" />
                <Button x:Name="AudioConvertButton" Content="Convert audio" Style="{StaticResource PrimaryButton}"
                        MinWidth="140" Click="ConvertAudio_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
