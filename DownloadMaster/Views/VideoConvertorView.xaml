<UserControl x:Class="DownloadMaster.Views.VideoConvertorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             DragOver="Video_DragOver"
             Drop="Video_Drop"
             DragLeave="Video_DragLeave">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MaxHeight="520" />
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="240" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" MinWidth="240" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="14" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="VideoSourceTitle" Text="Video source" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" />
                        <TextBlock x:Name="VideoSourceHint" Text="Single video file only"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12" />
                        <TextBlock x:Name="VideoFileLabel" Text="Video file" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="VideoInputPathBox" IsReadOnly="True" />
                            <Button x:Name="VideoBrowseInputButton" Grid.Column="1" Content="Browse"
                                    Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                    Click="BrowseVideoInput_Click" />
                        </Grid>
                        <TextBlock x:Name="VideoOperationLabel" Text="Operation" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                        <StackPanel Margin="0,0,0,12">
                            <RadioButton x:Name="VideoConvertRadio" Content="Convert — change to another format"
                                         GroupName="VideoOperation" IsChecked="True" />
                            <RadioButton x:Name="VideoOptimizeRadio" Content="Optimize — re-encode same format"
                                         GroupName="VideoOperation" />
                            <RadioButton x:Name="VideoToGifRadio" Content="To GIF — animated GIF from video"
                                         GroupName="VideoOperation" />
                            <RadioButton x:Name="VideoToFramesRadio" Content="To frame textures — extract image sequence"
                                         GroupName="VideoOperation" />
                        </StackPanel>
                        <StackPanel x:Name="VideoFormatPanel">
                            <TextBlock x:Name="VideoFormatLabel" Text="Target format" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <ComboBox x:Name="VideoFormatCombo" DisplayMemberPath="DisplayName" SelectedValuePath="Format" />
                        </StackPanel>
                        <StackPanel x:Name="VideoGifOptionsPanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock x:Name="GifFpsLabel" Text="GIF frame rate (FPS)" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="GifFpsSlider" Grid.Column="0" Minimum="1" Maximum="30" Value="10"
                                        TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Width="24" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="{Binding ElementName=GifFpsSlider, Path=Value, StringFormat={}{0:0}}" />
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="VideoFrameOptionsPanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock x:Name="FrameFormatLabel" Text="Frame image format" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <ComboBox x:Name="FrameFormatCombo" SelectedIndex="0">
                                <ComboBoxItem Content="PNG (recommended)" Tag="Png" />
                                <ComboBoxItem Content="JPEG" Tag="Jpg" />
                                <ComboBoxItem Content="BMP" Tag="Bmp" />
                                <ComboBoxItem Content="TGA" Tag="Tga" />
                            </ComboBox>
                            <TextBlock x:Name="FrameExtractLabel" Text="Extract mode" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,6" />
                            <RadioButton x:Name="EveryFrameRadio" Content="Every frame" GroupName="FrameExtract" IsChecked="True" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <RadioButton x:Name="TargetFpsFrameRadio" Content="Target FPS:" GroupName="FrameExtract" VerticalAlignment="Center" />
                                <Slider x:Name="FrameFpsSlider" Width="100" Margin="8,0,8,0" Minimum="1" Maximum="60" Value="12"
                                        TickFrequency="1" IsSnapToTickEnabled="True" IsEnabled="False" VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="{Binding ElementName=FrameFpsSlider, Path=Value, StringFormat={}{0:0}}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="14" VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock x:Name="VideoOutputTitle" Text="Output" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                    <TextBlock x:Name="VideoSaveToLabel" Text="Save to" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <StackPanel Margin="0,0,0,12">
                        <RadioButton x:Name="VideoSameFolderRadio" Content="Same folder (optimize in place or replace extension)"
                                     GroupName="VideoOutput" IsChecked="True" />
                        <RadioButton x:Name="VideoCustomFolderRadio" Content="Custom output folder" GroupName="VideoOutput" />
                    </StackPanel>
                    <Grid x:Name="VideoOutputFolderPanel" Margin="0,0,0,12" IsEnabled="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="VideoOutputFolderBox" IsReadOnly="True" />
                        <Button x:Name="VideoBrowseOutputButton" Grid.Column="1" Content="Browse"
                                Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                Click="BrowseVideoOutput_Click" />
                    </Grid>
                    <TextBlock x:Name="VideoResolutionLabel" Text="Resolution" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="VideoResolutionCombo" Margin="0,0,0,12" SelectedValuePath="Label">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" />
                                    <TextBlock Grid.Column="1" Text="{Binding DimensionsText}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="16,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock x:Name="VideoOperationHint"
                               Text="Convert re-encodes the video into the selected container and codec."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border x:Name="VideoInfoDropZone" Grid.Column="4" Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14"
                    AllowDrop="True" DragOver="Video_DragOver" Drop="Video_Drop" DragLeave="Video_DragLeave">
                <StackPanel>
                    <TextBlock x:Name="VideoInfoTitle" Text="Video info" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" MinHeight="120" Padding="12" Margin="0,0,0,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="VideoInfoTitleText" Text="Drop a video file" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="VideoInfoDetails" Text="Codec, resolution, duration, and size appear here."
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <TextBlock x:Name="VideoFfmpegStatus" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="VideoSupportedLabel" Text="Supported inputs" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBlock x:Name="VideoSupportedText"
                               Text="MP4, MKV, WebM, AVI, MOV, WMV, FLV, MPEG, M4V, TS, 3GP, OGV, ASF, and more."
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,12,0,12">
            <Grid MinHeight="100">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="60" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VideoResultsTitle" Text="Video result" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="VideoResultsSummaryText" Grid.Column="1" VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Text="No conversion yet" />
                </Grid>
                <ProgressBar x:Name="VideoResultsProgressBar" Grid.Row="1" Margin="0,10,0,10" Minimum="0" Maximum="100"
                               Value="0" Visibility="Collapsed" Height="6" />
                <ListView x:Name="VideoResultsList" Grid.Row="2" MinHeight="60" BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn x:Name="VideoResultStatusCol" Header="Status" Width="80" DisplayMemberBinding="{Binding Status}" />
                            <GridViewColumn x:Name="VideoResultFileCol" Header="File" Width="180" DisplayMemberBinding="{Binding FileName}" />
                            <GridViewColumn x:Name="VideoResultSizeCol" Header="Size change" Width="200" DisplayMemberBinding="{Binding SizeChange}" />
                            <GridViewColumn x:Name="VideoResultDetailsCol" Header="Details" Width="360" DisplayMemberBinding="{Binding Detail}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="VideoStatusText" Text="Ready" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
                <ProgressBar x:Name="VideoProgressBar" Margin="0,8,16,0" Minimum="0" Maximum="100" Value="0"
                             Visibility="Collapsed" Height="6" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="VideoClearResultsButton" Content="Clear result" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0" Click="ClearVideoResults_Click" />
                <Button x:Name="VideoConvertButton" Content="Convert video" Style="{StaticResource PrimaryButton}"
                        MinWidth="140" Click="ConvertVideo_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
