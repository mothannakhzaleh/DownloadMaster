<Window x:Class="DownloadMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DownloadMaster.Views"
        Title="DownloadMaster"
        Icon="Assets/app.ico"
        Height="900" Width="1080"
        MinHeight="640" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid x:Name="RootLayoutGrid" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="220" />
            <RowDefinition x:Name="DownloadQueueRow" Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Image Source="/Assets/app-icon.png" Width="40" Height="40" Margin="0,0,14,0" RenderOptions.BitmapScalingMode="HighQuality" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="DownloadMaster" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="SubtitleText" Text="Multi-platform video download manager"
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <ComboBox x:Name="LanguageCombo" Width="130" Margin="0,0,10,0" SelectionChanged="LanguageCombo_SelectionChanged" />
                <Button x:Name="ThemeButton" Content="Theme" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="ThemeButton_Click" />
                <Button x:Name="AboutButton" Content="About" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="AboutButton_Click" />
                <Button x:Name="SettingsButton" Content="Settings" Style="{StaticResource SecondaryButton}" Click="SettingsButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Source tabs -->
        <TabControl x:Name="SourceTabs" Grid.Row="1" Margin="0,0,0,16" VerticalAlignment="Stretch"
                    Background="Transparent" BorderThickness="0"
                    SelectionChanged="SourceTabs_SelectionChanged">
            <TabItem x:Name="VideoTab" Header="Video">
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UrlBox" />
                            <Button x:Name="FetchButton" Grid.Column="1" Content="Fetch" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="FetchButton_Click" />
                            <Button x:Name="DownloadButton" Grid.Column="2" Content="Download" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="DownloadButton_Click" />
                        </Grid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock x:Name="QualityLabel" Text="Quality" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                            <ComboBox x:Name="QualityCombo" MinWidth="90" />
                            <TextBlock x:Name="FormatLabel" Text="Format" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="16,0,8,0" />
                            <ComboBox x:Name="FormatCombo" MinWidth="90" />
                        </StackPanel>
                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SavePathLabel" Text="Save to" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                            <TextBox x:Name="SavePathBox" Grid.Column="1" />
                            <Button x:Name="BrowseSavePathButton" Grid.Column="2" Content="..." Margin="8,0,0,0"
                                    Style="{StaticResource SecondaryButton}" Padding="12,10" Click="BrowseSavePath_Click" />
                        </Grid>
                        <TextBlock x:Name="PreviewText" Grid.Row="3" Margin="0,12,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Visibility="Collapsed" />
                    </Grid>
                </Border>
            </TabItem>

            <TabItem x:Name="InstagramTab" Header="Instagram">
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,8,0,0"
                        VerticalAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="InstagramBrowseRow" Height="0" MinHeight="0" />
                        </Grid.RowDefinitions>
                            <TextBlock x:Name="InstagramHintText" TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" />
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InstagramUrlBox" />
                                <Button x:Name="InstagramFetchButton" Grid.Column="1" Content="Fetch" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="InstagramFetchButton_Click" />
                                <Button x:Name="InstagramDownloadButton" Grid.Column="2" Content="Download" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="InstagramDownloadButton_Click" />
                            </Grid>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock x:Name="InstagramBrowserLabel" Text="Browser for login" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                                <ComboBox x:Name="InstagramBrowserCombo" MinWidth="160" SelectionChanged="InstagramBrowserCombo_SelectionChanged" />
                                <Button x:Name="InstagramLoginButton" Content="Open Instagram login" Style="{StaticResource SecondaryButton}"
                                        Margin="12,0,0,0" Click="InstagramLoginButton_Click" />
                            </StackPanel>
                            <WrapPanel Grid.Row="3" Margin="0,12,0,0">
                                <Button x:Name="InstagramImportCookiesButton" Content="Add cookies..." Style="{StaticResource SecondaryButton}"
                                        Click="InstagramImportCookiesButton_Click" />
                                <Button x:Name="InstagramSyncCookiesButton" Content="Sync from browser" Style="{StaticResource SecondaryButton}"
                                        Margin="10,0,0,0" Click="InstagramSyncCookiesButton_Click" />
                                <Button x:Name="InstagramClearCookiesButton" Content="Clear cookies" Style="{StaticResource SecondaryButton}"
                                        Margin="10,0,0,0" Click="InstagramClearCookiesButton_Click" />
                                <TextBlock x:Name="InstagramCookiesStatusText" VerticalAlignment="Center" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,8,0,0" />
                            </WrapPanel>
                            <Grid Grid.Row="4" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="InstagramSavePathLabel" Text="Save to" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                                <TextBox x:Name="InstagramSavePathBox" Grid.Column="1" TextChanged="InstagramSavePathBox_TextChanged" />
                                <Button x:Name="InstagramBrowseSavePathButton" Grid.Column="2" Content="..." Margin="8,0,0,0"
                                        Style="{StaticResource SecondaryButton}" Padding="12,10" Click="InstagramBrowseSavePath_Click" />
                            </Grid>
                            <TextBlock x:Name="InstagramPreviewText" Grid.Row="5" Margin="0,12,0,0" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Visibility="Collapsed" />
                            <Border x:Name="InstagramBrowsePanel" Grid.Row="6" Margin="0,12,0,0" Visibility="Collapsed"
                                    VerticalAlignment="Stretch"
                                    Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="12" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" MinHeight="120" />
                                    </Grid.RowDefinitions>
                                    <WrapPanel Margin="0,0,0,10">
                                        <Button x:Name="InstagramDownloadSelectedButton" Content="Download selected" Style="{StaticResource PrimaryButton}" Click="InstagramDownloadSelectedButton_Click" />
                                        <Button x:Name="InstagramSelectAllButton" Content="Select all" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="InstagramSelectAllButton_Click" />
                                        <Button x:Name="InstagramExpandAllButton" Content="Expand all" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="InstagramExpandAllButton_Click" />
                                        <Button x:Name="InstagramCollapseAllButton" Content="Collapse all" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="InstagramCollapseAllButton_Click" />
                                        <Button x:Name="InstagramClearBrowseButton" Content="Clear list" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="InstagramClearBrowseButton_Click" />
                                    </WrapPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="InstagramSectionsPanel" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
            </TabItem>

            <TabItem x:Name="FileDownloadTab" Header="Files">
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="FileDownloadHintText" TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FileDownloadUrlBox" />
                            <Button x:Name="FileDownloadButton" Grid.Column="1" Content="Download"
                                    Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="FileDownloadButton_Click" />
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FileDownloadNameLabel" Text="File name" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                            <TextBox x:Name="FileDownloadNameBox" Grid.Column="1" />
                        </Grid>
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock x:Name="FileDownloadConnectionsLabel" Text="Connections" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                            <ComboBox x:Name="FileDownloadConnectionsCombo" MinWidth="80" SelectedIndex="1">
                                <ComboBoxItem Content="4" />
                                <ComboBoxItem Content="8" />
                                <ComboBoxItem Content="12" />
                                <ComboBoxItem Content="16" />
                            </ComboBox>
                        </StackPanel>
                        <Grid Grid.Row="4" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FileDownloadSavePathLabel" Text="Save to" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                            <TextBox x:Name="FileDownloadSavePathBox" Grid.Column="1" />
                            <Button x:Name="FileDownloadBrowseSavePathButton" Grid.Column="2" Content="..." Margin="8,0,0,0"
                                    Style="{StaticResource SecondaryButton}" Padding="12,10" Click="FileDownloadBrowseSavePath_Click" />
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem x:Name="ConvertTab" Header="Convert">
                <TabControl x:Name="ConvertSubTabs" Style="{StaticResource NestedTabControl}" Margin="0,8,0,0">
                    <TabItem x:Name="VideoConvertSubTab" Header="Video Convert">
                        <views:VideoConvertorView x:Name="VideoConvertorPanel" />
                    </TabItem>
                    <TabItem x:Name="ImageConvertSubTab" Header="Image Convert">
                        <views:ImageConvertorView x:Name="ImageConvertorPanel" />
                    </TabItem>
                    <TabItem x:Name="AudioConvertSubTab" Header="Audio Convert">
                        <views:AudioConvertorView x:Name="AudioConvertorPanel" />
                    </TabItem>
                    <TabItem x:Name="SpeechConvertSubTab" Header="Speech">
                        <views:SpeechConvertorView x:Name="SpeechConvertorPanel" />
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>

        <!-- Queue -->
        <Expander x:Name="DownloadQueueExpander" Grid.Row="2" IsExpanded="False"
                  Expanded="DownloadQueueExpander_Expanded" Collapsed="DownloadQueueExpander_Collapsed"
                  Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1" Padding="12">
            <Expander.Header>
                <TextBlock x:Name="DownloadQueueHeader" Text="Downloads" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </Expander.Header>
            <Grid MinHeight="120">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button x:Name="ClearListButton" Grid.Row="0" Content="Clear list"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right"
                        Margin="0,0,0,10" Padding="12,6" Visibility="Collapsed" Click="ClearListButton_Click" />
                <Grid Grid.Row="1">
                    <TextBlock x:Name="EmptyText" Text="No downloads yet. Paste a URL to get started."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="15" />
                    <ListView x:Name="DownloadList" Background="Transparent" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,8" />
                                    <ProgressBar Grid.Row="2" Value="{Binding Progress}" Maximum="100" Height="8" Margin="0,0,0,8" />
                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding SpeedText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding EtaText}" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Click="CopyDownloadDetails_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource CopyDetailsLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanCopyDiagnostics}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="RemoveDownload_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource RemoveLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="RetryDownload_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource RetryLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanRetry}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="PauseDownload_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource PauseLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanPause}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="ResumeDownload_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource ResumeLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanResume}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="CancelDownload_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource CancelLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanCancel}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="OpenFolder_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource OpenFolderLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanOpenFolder}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="PlayVideo_Click" Tag="{Binding Id}" IsEnabled="{Binding CanPlay}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource PlayLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Expander>

        <!-- Status -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                       TextWrapping="Wrap" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center">
                    <Run Text="© 2026 " />
                    <Hyperlink NavigateUri="https://github.com/mothannakhzaleh/DownloadMaster" RequestNavigate="CopyrightLink_RequestNavigate">mothannakh</Hyperlink>
                    <Run Text=" · " />
                    <Hyperlink NavigateUri="https://satisfy.live/" RequestNavigate="CopyrightLink_RequestNavigate">satisfy.live</Hyperlink>
                    <Run Text=" · " />
                    <Hyperlink NavigateUri="https://www.youtube.com/@ToPSourceDevelopment" RequestNavigate="CopyrightLink_RequestNavigate">YouTube</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
