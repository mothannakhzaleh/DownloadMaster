<Window x:Class="DownloadMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DownloadMaster"
        Icon="Assets/app.ico"
        Height="820" Width="1080"
        MinHeight="640" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Image Source="/Assets/app-icon.png" Width="40" Height="40" Margin="0,0,14,0" RenderOptions.BitmapScalingMode="HighQuality" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="DownloadMaster" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock x:Name="SubtitleText" Text="Multi-platform video download manager"
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <ComboBox x:Name="LanguageCombo" Width="130" Margin="0,0,10,0" SelectionChanged="LanguageCombo_SelectionChanged" />
                <Button x:Name="ThemeButton" Content="Theme" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="ThemeButton_Click" />
                <Button x:Name="SettingsButton" Content="Settings" Style="{StaticResource SecondaryButton}" Click="SettingsButton_Click" />
            </StackPanel>
        </Grid>

        <!-- URL bar -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="14" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UrlBox" />
                    <Button x:Name="FetchButton" Grid.Column="1" Content="Fetch" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="FetchButton_Click" />
                    <Button x:Name="DownloadButton" Grid.Column="2" Content="Download" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="DownloadButton_Click" />
                </Grid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock x:Name="QualityLabel" Text="Quality" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                    <ComboBox x:Name="QualityCombo" MinWidth="90" />
                    <TextBlock x:Name="FormatLabel" Text="Format" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="16,0,8,0" />
                    <ComboBox x:Name="FormatCombo" MinWidth="90" />
                </StackPanel>
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SavePathLabel" Text="Save to" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                    <TextBox x:Name="SavePathBox" Grid.Column="1" />
                    <Button x:Name="BrowseSavePathButton" Grid.Column="2" Content="..." Margin="8,0,0,0"
                            Style="{StaticResource SecondaryButton}" Padding="12,10" Click="BrowseSavePath_Click" />
                </Grid>
                <TextBlock x:Name="PreviewText" Grid.Row="3" Margin="0,12,0,0" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}" Visibility="Collapsed" />
            </Grid>
        </Border>

        <!-- Queue -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="14" Padding="12">
            <Grid>
                <TextBlock x:Name="EmptyText" Text="No downloads yet. Paste a URL to get started."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="15" />
                <ListView x:Name="DownloadList" Background="Transparent" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceElevatedBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,8" />
                                    <ProgressBar Grid.Row="2" Value="{Binding Progress}" Maximum="100" Height="8" Margin="0,0,0,8" />
                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding SpeedText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding EtaText}" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Click="CancelDownload_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource CancelLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanCancel}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="OpenFolder_Click" Tag="{Binding Id}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource OpenFolderLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Margin" Value="0,0,8,0" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanOpenFolder}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Click="PlayVideo_Click" Tag="{Binding Id}" IsEnabled="{Binding CanPlay}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                        <Setter Property="Content" Value="{DynamicResource PlayLabel}" />
                                                        <Setter Property="Padding" Value="10,6" />
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Status -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                       TextWrapping="Wrap" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center">
                    <Run Text="© 2026 mothannakh · " />
                    <Hyperlink NavigateUri="https://satisfy.live/" RequestNavigate="CopyrightLink_RequestNavigate">satisfy.live</Hyperlink>
                    <Run Text=" · " />
                    <Hyperlink NavigateUri="https://www.youtube.com/@ToPSourceDevelopment" RequestNavigate="CopyrightLink_RequestNavigate">YouTube</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
